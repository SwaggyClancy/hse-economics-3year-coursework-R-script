library(ggplot2)
library(scales)
# Данные
data <- data.frame(
year = c(2003, 2004, 2005, 2008, 2011, 2016, 2019, 2023, 2025),
users_millions = c(0.001, 1, 5, 30, 100, 500, 660, 1000, 1200)
)
# График
ggplot(data, aes(x = year, y = users_millions)) +
geom_line(color = "#0077B5", size = 1.5) +
geom_point(color = "#0077B5", size = 4) +
geom_text(aes(label = comma(users_millions, accuracy = 1)),
vjust = -0.8, color = "#0077B5", size = 4.5, fontface = "bold") +
scale_y_continuous(labels = comma,
limits = c(0, 1300),
breaks = seq(0, 1200, 200)) +
scale_x_continuous(breaks = data$year) +
labs(
title = "LinkedIn User Growth (2003–2025)",
subtitle = "Total registered members, millions",
x = "Year",
y = "Users, millions",
caption = "Sources: LinkedIn, Microsoft reports, DemandSage, Statista (2025)"
) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(face = "bold", color = "#0077B5", size = 18, hjust = 0.5),
plot.subtitle = element_text(color = "gray30", hjust = 0.5),
axis.title = element_text(color = "gray30"),
axis.text = element_text(color = "gray30"),
panel.grid.major.x = element_blank(),
panel.grid.minor = element_blank(),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
# Сохранить график
ggsave("linkedin_growth_en.png", width = 12, height = 7, dpi = 300, bg = "white")
