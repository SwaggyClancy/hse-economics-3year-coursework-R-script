library(httr)
library(jsonlite)
ask_deepseek <- function(prompt) {
# Получаем ключ из .Renviron
api_key <- Sys.getenv("DEEPSEEK_API_KEY")
# Проверяем, есть ли ключ
if (api_key == "") {
stop("Ключ API не найден! Проверь файл .Renviron")
}
# URL для API DeepSeek
url <- "https://api.deepseek.com/v1/chat/completions"
# Формируем тело запроса
body <- list(
model = "deepseek-chat",
messages = list(
list(
role = "user",
content = prompt
)
),
temperature = 0.7  # можно менять от 0 до 2 (креативность ответов)
)
# Отправляем запрос
cat("Отправляю запрос к DeepSeek...\n")
response <- POST(
url,
add_headers(
"Authorization" = paste("Bearer", api_key),
"Content-Type" = "application/json"
),
body = toJSON(body, auto_unbox = TRUE),
encode = "json"
)
# Проверяем, не было ли ошибки
if (status_code(response) != 200) {
error_text <- content(response, "text")
stop("Ошибка API (код ", status_code(response), "): ", error_text)
}
# Получаем содержимое ответа
result <- content(response, "parsed")
# Извлекаем текст ответа
answer <- result$choices[[1]]$message$content
return(answer)
}
library(httr)
library(jsonlite)
ask_deepseek <- function(prompt) {
# Получаем ключ из .Renviron
api_key <- Sys.getenv("DEEPSEEK_API_KEY")
# Проверяем, есть ли ключ
if (api_key == "") {
stop("Ключ API не найден! Проверь файл .Renviron")
}
# URL для API DeepSeek
url <- "https://api.deepseek.com/v1/chat/completions"
# Формируем тело запроса
body <- list(
model = "deepseek-chat",
messages = list(
list(
role = "user",
content = prompt
)
),
temperature = 0.7  # можно менять от 0 до 2 (креативность ответов)
)
# Отправляем запрос
cat("Отправляю запрос к DeepSeek...\n")
response <- POST(
url,
add_headers(
"Authorization" = paste("Bearer", api_key),
"Content-Type" = "application/json"
),
body = toJSON(body, auto_unbox = TRUE),
encode = "json"
)
# Проверяем, не было ли ошибки
if (status_code(response) != 200) {
error_text <- content(response, "text")
stop("Ошибка API (код ", status_code(response), "): ", error_text)
}
# Получаем содержимое ответа
result <- content(response, "parsed")
# Извлекаем текст ответа
answer <- result$choices[[1]]$message$content
return(answer)
}
