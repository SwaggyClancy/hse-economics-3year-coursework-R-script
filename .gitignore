# ================== Игнорируем большие/генерируемые данные ==================
data/processed/*
data/raw/*
output/plots/*
output/tables/*

# Сохраняем структуру папок
!data/processed/.gitkeep
!data/raw/.gitkeep
!output/plots/.gitkeep
!output/tables/.gitkeep

# ================== R-specific ==================
.Rhistory
.RData
.RDataTmp
*.rds
*.Rproj
.Rproj.user/
renv/library/
renv/python/
.cache/

# ================== Временные и служебные файлы ==================
*.log
*.tmp
*.bak
__pycache__/
.DS_Store
Thumbs.db

