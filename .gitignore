# =============================================
# .gitignore — только скрипты
# =============================================

# Игнорируем все данные и результаты
data/processed/*
data/raw/*
output/plots/*
output/tables/*

# Сохраняем структуру пустых папок
!data/processed/.gitkeep
!data/raw/.gitkeep
!output/plots/.gitkeep
!output/tables/.gitkeep

# R временные файлы
.Rhistory
.RData
.RDataTmp
*.rds
*.Rproj
.Rproj.user/

# Дополнительно
renv/library/
renv/python/
.cache/

# Мусор
*.log
*.tmp
*.bak
__pycache__/
.DS_Store
Thumbs.db